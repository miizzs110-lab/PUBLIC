let cameraPushIn = null;
(function scene3d(){
  const canvas = document.getElementById('three-bg');
  if(!window.THREE){ canvas.style.display='none'; return; }
  let W=innerWidth, H=innerHeight;
  const renderer = new THREE.WebGLRenderer({canvas, antialias:true, alpha:true});
  renderer.setSize(W,H); renderer.setPixelRatio(Math.min(devicePixelRatio,2));
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0xEBE2D3, 0.03);
  const camera = new THREE.PerspectiveCamera(55, W/H, 0.1, 120);
  camera.position.set(0,0,(reduce?20:60));
  scene.add(new THREE.AmbientLight(0xC8BCA6, 1.05));
  const key = new THREE.DirectionalLight(0xFFF6E8, 1.0); key.position.set(6,9,7); scene.add(key);
  const blue = new THREE.PointLight(0x2F5C8A, 1.15, 70); blue.position.set(-9,-3,12); scene.add(blue);
  const gold = new THREE.PointLight(0xC29A4B, 0.75, 60); gold.position.set(10,7,-8); scene.add(gold);
  function paperTex(){
    const c=document.createElement('canvas'); c.width=256; c.height=340;
    const x=c.getContext('2d'); x.fillStyle='#FBF7F0'; x.fillRect(0,0,256,340);
    x.fillStyle='rgba(47,92,138,0.16)';
    for(let y=34;y<312;y+=18) x.fillRect(26,y,40+Math.random()*168,4);
    return new THREE.CanvasTexture(c);
  }
  const paperMat = new THREE.MeshStandardMaterial({map:paperTex(),color:0xFBF7F0,roughness:.95,metalness:.02,side:THREE.DoubleSide});
  const creamMat = new THREE.MeshStandardMaterial({color:0xEAE0CF,roughness:.9,metalness:.03,side:THREE.DoubleSide});
  const blueMat  = new THREE.MeshStandardMaterial({color:0x2F5C8A,roughness:.6,metalness:.15});
  const penMat   = new THREE.MeshStandardMaterial({color:0x16314C,roughness:.4,metalness:.45});
  const goldMat  = new THREE.MeshStandardMaterial({color:0xC29A4B,roughness:.3,metalness:.8});
  const inkMat   = new THREE.MeshStandardMaterial({color:0x14283C,roughness:.15,metalness:.55});
  const paperGeo=new THREE.BoxGeometry(2.6,3.4,0.05);
  const sheetGeo=new THREE.BoxGeometry(2.2,3.0,0.04);
  const inkGeo  =new THREE.SphereGeometry(0.28,18,18);
  function makePen(){const g=new THREE.Group();
    const body=new THREE.Mesh(new THREE.CylinderGeometry(.085,.085,2.6,14),penMat);
    const nib =new THREE.Mesh(new THREE.ConeGeometry(.085,.5,14),goldMat); nib.position.y=-1.55;
    const cap =new THREE.Mesh(new THREE.CylinderGeometry(.105,.105,.55,14),goldMat); cap.position.y=1.25;
    g.add(body,nib,cap); return g;}
  function makeBook(){const g=new THREE.Group();
    const L=new THREE.Mesh(new THREE.BoxGeometry(1.8,2.4,0.08),blueMat);
    const R=L.clone();
    const PL=new THREE.Mesh(new THREE.BoxGeometry(1.7,2.3,0.04),paperMat);
    const PR=PL.clone();
    L.position.x=-0.95; R.position.x=0.95; PL.position.set(-0.92,0,0.07); PR.position.set(0.92,0,0.07);
    L.rotation.y=0.5; R.rotation.y=-0.5; PL.rotation.y=0.5; PR.rotation.y=-0.5;
    g.add(L,R,PL,PR); return g;}
  function makeQuill(){const g=new THREE.Group();
    const shaft=new THREE.Mesh(new THREE.CylinderGeometry(.04,.07,2.4,10),blueMat);
    const feather=new THREE.Mesh(new THREE.BoxGeometry(.5,1.6,.02),goldMat); feather.position.y=.7; feather.rotation.z=.12;
    const tip=new THREE.Mesh(new THREE.ConeGeometry(.07,.4,10),goldMat); tip.position.y=-1.4;
    g.add(shaft,feather,tip); return g;}
  const objs=[], COUNT=(touch?18:38), sx=18, sy=13, sz=18;
  for(let i=0;i<COUNT;i++){
    const r=Math.random(); let m;
    if(r<0.40)      m=new THREE.Mesh(Math.random()<.5?paperGeo:sheetGeo, Math.random()<.5?paperMat:creamMat);
    else if(r<0.62) m=makePen();
    else if(r<0.78) m=makeBook();
    else if(r<0.90) m=makeQuill();
    else { m=new THREE.Mesh(inkGeo,inkMat); m.scale.set(1,1.35,1); }
    m.position.set((Math.random()-.5)*sx,(Math.random()-.5)*sy,(Math.random()-.5)*sz-4);
    m.rotation.set(Math.random()*6,Math.random()*6,Math.random()*6);
    m.userData={vy:.004+Math.random()*.012, sway:.3+Math.random()*.7, phase:Math.random()*6.28,
      rx:(Math.random()-.5)*.005, ry:(Math.random()-.5)*.006, rz:(Math.random()-.5)*.004};
    scene.add(m); objs.push(m);
  }
  const SMOKE=touch?100:220;
  const pg=new THREE.BufferGeometry(), pos=new Float32Array(SMOKE*3), spd=new Float32Array(SMOKE);
  for(let i=0;i<SMOKE;i++){pos[i*3]=(Math.random()-.5)*30;pos[i*3+1]=(Math.random()-.5)*22;pos[i*3+2]=(Math.random()-.5)*20-4;spd[i]=.006+Math.random()*.02;}
  pg.setAttribute('position',new THREE.BufferAttribute(pos,3));
  function dot(){const c=document.createElement('canvas');c.width=c.height=64;const x=c.getContext('2d');
    const grd=x.createRadialGradient(32,32,0,32,32,32);grd.addColorStop(0,'rgba(47,92,138,.45)');grd.addColorStop(1,'rgba(47,92,138,0)');
    x.fillStyle=grd;x.fillRect(0,0,64,64);return new THREE.CanvasTexture(c);}
  const smoke=new THREE.Points(pg,new THREE.PointsMaterial({size:.8,map:dot(),transparent:true,depthWrite:false,opacity:.28}));
  scene.add(smoke);
  let mx=0,my=0;
  addEventListener('mousemove',e=>{mx=e.clientX/innerWidth-.5;my=e.clientY/innerHeight-.5;},{passive:true});
  addEventListener('resize',()=>{W=innerWidth;H=innerHeight;camera.aspect=W/H;camera.updateProjectionMatrix();renderer.setSize(W,H);});
  const top=sy/2+2, bottom=-sy/2-2; let running=true;
  document.addEventListener('visibilitychange',()=>{running=!document.hidden; if(running&&!reduce) tick();});
  cameraPushIn = function(){ if(reduce||!window.gsap){camera.position.z=20;return;} gsap.to(camera.position,{z:20,duration:1.8,ease:'power3.out'}); };
  function frame(){
    const t=performance.now()*.001;
    objs.forEach(o=>{const u=o.userData;
      o.position.y+=u.vy; o.position.x+=Math.sin(t*.5+u.phase)*.002*u.sway;
      o.rotation.x+=u.rx; o.rotation.y+=u.ry; o.rotation.z+=u.rz;
      if(o.position.y>top){o.position.y=bottom;o.position.x=(Math.random()-.5)*sx;}});
    const p=smoke.geometry.attributes.position.array;
    for(let i=0;i<SMOKE;i++){p[i*3+1]+=spd[i]; p[i*3]+=Math.sin(t*.3+i)*.002; if(p[i*3+1]>13)p[i*3+1]=-13;}
    smoke.geometry.attributes.position.needsUpdate=true;
    const sN=maxScroll?Math.min(1,currentScroll/maxScroll):0;
    camera.position.x += (mx*4 - camera.position.x)*.04;
    if(camera.position.z<=20.5){ camera.position.y += ((-my*3 - sN*6) - camera.position.y)*.04; }
    camera.lookAt(0,-sN*4,0);
    renderer.render(scene,camera);
  }
  function tick(){ if(!running) return; frame(); requestAnimationFrame(tick); }
  reduce ? frame() : tick();
})();

function onScrollShared(){ document.getElementById('nav').classList.toggle('scrolled', currentScroll>40); }
function initSmooth(){
  if(window.gsap) gsap.registerPlugin(ScrollTrigger);
  const container=document.querySelector('[data-scroll-container]');
  if(reduce || touch || !window.LocomotiveScroll){ nativeScroll(); return; }
  try{
    loco=new LocomotiveScroll({el:container,smooth:true,lerp:.085,multiplier:1});
    loco.on('scroll',(o)=>{currentScroll=o.scroll.y; if(o.limit) maxScroll=o.limit.y||maxScroll; if(window.ScrollTrigger)ScrollTrigger.update(); onScrollShared();});
    if(window.ScrollTrigger){
      ScrollTrigger.scrollerProxy(container,{
        scrollTop(v){return arguments.length?loco.scrollTo(v,{duration:0,disableLerp:true}):loco.scroll.instance.scroll.y;},
        getBoundingClientRect(){return{top:0,left:0,width:innerWidth,height:innerHeight};},
        pinType:container.style.transform?'transform':'fixed'
      });
      ScrollTrigger.addEventListener('refresh',()=>loco&&loco.update());
      ScrollTrigger.defaults({scroller:container});
    }
  }catch(e){ loco=null; nativeScroll(); }
}
function nativeScroll(){
  addEventListener('scroll',()=>{currentScroll=scrollY;maxScroll=document.documentElement.scrollHeight-innerHeight;onScrollShared();},{passive:true});
}
function scrollToTarget(sel){
  const el=document.querySelector(sel); if(!el) return;
  if(loco) loco.scrollTo(el); else el.scrollIntoView({behavior:reduce?'auto':'smooth'});
}

function runIntro(done){
  const intro=document.getElementById('intro');
  if(reduce || !window.gsap){ if(intro) intro.style.display='none'; done(); return; }
  const tl=gsap.timeline({onComplete:()=>{intro.style.display='none'; done();}});
  tl.to('#intro .tag',{opacity:1,duration:.5})
    .to('#intro .bar i',{width:'100%',duration:1.0,ease:'power1.inOut'},'-=.3')
    .to('#intro',{yPercent:-100,duration:.8,ease:'power3.inOut'},'+=.15')
    .add(()=>cameraPushIn && cameraPushIn(),'-=.8');
}

