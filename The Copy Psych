if(!touch && !reduce){
  const dot=document.querySelector('.cursor-dot'), ring=document.querySelector('.cursor-ring');
  let rx=0,ry=0,tx=0,ty=0,last=0;
  addEventListener('mousemove',e=>{
    tx=e.clientX;ty=e.clientY; dot.style.transform=`translate(${tx}px,${ty}px) translate(-50%,-50%)`;
    const now=performance.now();
    if(now-last>55){last=now;
      const ink=document.createElement('div');ink.className='ink';
      const s=6+Math.random()*8; ink.style.width=ink.style.height=s+'px';
      ink.style.left=tx+'px'; ink.style.top=ty+'px'; ink.style.opacity='.55';
      document.body.appendChild(ink);
      requestAnimationFrame(()=>{ink.style.opacity='0';ink.style.transform='translate(-50%,-50%) scale(.2)';});
      setTimeout(()=>ink.remove(),750);
    }
  });
  (function loop(){rx+=(tx-rx)*.18;ry+=(ty-ry)*.18;ring.style.transform=`translate(${rx}px,${ry}px) translate(-50%,-50%)`;requestAnimationFrame(loop);})();
  const hot=()=>ring.classList.add('is-hot'), cold=()=>ring.classList.remove('is-hot');
  document.addEventListener('mouseover',e=>{if(e.target.closest('a,button,.work,.svc,.badge,.chip,[data-hot]'))hot();});
  document.addEventListener('mouseout',e=>{if(e.target.closest('a,button,.work,.svc,.badge,.chip,[data-hot]'))cold();});
}

